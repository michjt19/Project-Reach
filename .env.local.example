# Copy this file to .env.local for local development
# Set these same variables in your Vercel project dashboard

# ── Sanity CMS (optional — site works without these using static fallbacks) ──
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production

# ── Volunteer form email notifications (optional — Formspree handles form if unset) ──
# Get key at resend.com after verifying noreply@thereachcommunity.com
RESEND_API_KEY=re_your_api_key
VOLUNTEER_NOTIFY_EMAIL=projectreachplatform@gmail.com
